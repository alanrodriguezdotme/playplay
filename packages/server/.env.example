DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-random-secret"
OTP_TTL_SECONDS=300
MUSIC_LIBRARY_PATH="./music"
PORT=3001

# Spotify credentials are configured via `pnpm setup` or the Admin Settings UI
# and stored encrypted in the database. The legacy SPOTIFY_CLIENT_ID /
# SPOTIFY_CLIENT_SECRET / SPOTIFY_RELAY_URL env vars are still honored as a
# fallback for existing installs.

